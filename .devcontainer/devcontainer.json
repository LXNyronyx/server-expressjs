{
  "name": "Express.js Development Container",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  
  "features": {},

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "christian-kohler.path-intellisense"
      ]
    }
  },

  "forwardPorts": [3000],

  "postCreateCommand": "cd src && npm install",

  "remoteUser": "node"
}
